{
    "name": "CS2 ban checker",
    "description": "Check ban status of players you encountered in CS2 matchmaking.",
    "version": "3.0.6",
    "permissions": [
        "unlimitedStorage",
        "storage",
        "contextMenus",
        "https://steamcommunity.com/*",
        "https://api.steampowered.com/*"
    ],
    "icons": {
        "16": "icon-16.png",
        "32": "icon-32.png",
        "48": "icon-48.png",
        "128": "icon-128.png"
    },
    "background": {
        "scripts": ["service_worker.js"]
    },
    "content_scripts": [
        {
            "js": ["index.js", "polyfills.js", "main.js"],
            "css": ["styles.css"],
            "run_at": "document_end",
            "matches": ["https://steamcommunity.com/id/*", "https://steamcommunity.com/profiles/*"]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "{77ad710c-4e82-db44-a0c8-a047fc834d60}"
        }
    },
    "manifest_version": 2
}
