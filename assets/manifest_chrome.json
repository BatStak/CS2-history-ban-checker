{
    "name": "CS2 ban checker",
    "description": "Check ban status of players you encountered in CS2 matchmaking.",
    "version": "3.0.8",
    "permissions": ["unlimitedStorage", "storage", "contextMenus"],
    "host_permissions": ["https://steamcommunity.com/*", "https://api.steampowered.com/*"],
    "icons": {
        "16": "icon-16.png",
        "32": "icon-32.png",
        "48": "icon-48.png",
        "128": "icon-128.png"
    },
    "background": {
        "service_worker": "service_worker.js"
    },
    "content_scripts": [
        {
            "js": ["index.js", "main.js"],
            "css": ["styles.css"],
            "run_at": "document_end",
            "matches": ["https://steamcommunity.com/id/*", "https://steamcommunity.com/profiles/*"]
        }
    ],
    "manifest_version": 3
}
